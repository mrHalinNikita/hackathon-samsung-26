# APP 
APP_NAME=pd-scanner
APP_ENV=prod
LOG_LEVEL=INFO

#  POSTGRESQl
POSTGRES_HOST=pd-postgres
POSTGRES_PORT=5432
POSTGRES_DB=pd_scanner
POSTGRES_USER=scanner
POSTGRES_PASSWORD=top-password
POSTGRES_SSLMODE=disable

# REDIS
REDIS_HOST=pd-redis
REDIS_PORT=6379
REDIS_PASSWORD=top-password
REDIS_DB=0

# KAFKA
KAFKA_BROKER=pd-kafka-0.pd-kafka.pd-scanner.svc.cluster.local
KAFKA_PORT=9092
KAFKA_TOPIC_RAW_FILES=raw_files
KAFKA_TOPIC_EXTRACTED_TEXT=extracted_text
KAFKA_TOPIC_RESULTS=pd_results

# SPARK
SPARK_MASTER_HOST=pd-spark-master
SPARK_MASTER_PORT=7077
SPARK_UI_PORT=8080
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=2

#  OCR
OCR_HOST=pd-ocr-service
OCR_PORT=8000
OCR_LOG_LEVEL=INFO
OCR_REDIS_URL=redis://:REDIS_PASSWORD@pd-redis:6379/1
OCR_TESSERACT_LANGS=rus+eng
OCR_MAX_IMAGE_SIZE_MB=50
OCR_MIN_CONFIDENCE=60

# DETECTOR
DETECTOR_REGEX_ENABLED=true
DETECTOR_REGEX_MIN_CONFIDENCE=0.8
DETECTOR_NLP_ENABLED=true
DETECTOR_NLP_MIN_CONFIDENCE=0.6
DETECTOR_ENSEMBLE_STRATEGY=weighted
DETECTOR_FINAL_MIN_CONFIDENCE=0.7